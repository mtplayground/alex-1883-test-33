# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
PUBLIC_APP_URL=https://example.com

# PostgreSQL. Persistent state must use PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://example.com/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile

# JWT signing. Use at least 32 random characters in production.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=alex-1883-test-33
JWT_AUDIENCE=alex-1883-test-33:web
JWT_EXPIRES_IN_SECONDS=604800

# S3-compatible object storage
OBJECT_STORAGE_ENDPOINT=https://object-storage.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=replace-with-bucket-name
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-key
OBJECT_STORAGE_PREFIX=uploads
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
