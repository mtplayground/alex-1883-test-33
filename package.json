{
  "name": "alex-1883-test-33",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "node scripts/validate-env.mjs --schema-only && node scripts/check-error-contract.mjs",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "check": "npm run build && npm run typecheck && npm run lint && npm run format:check",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "dev": "npm run dev:backend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma",
    "test": "npm run build && npm run test:backend && npm run test:frontend && npm run test:e2e",
    "test:backend": "node --test tests/backend/*.test.mjs",
    "test:e2e": "node --test tests/e2e/*.test.mjs",
    "test:frontend": "node --test tests/frontend/*.test.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "validate:env": "node scripts/validate-env.mjs",
    "start": "npm --workspace backend run start"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.729.0",
    "@aws-sdk/s3-request-presigner": "^3.729.0",
    "@prisma/client": "^7.4.1",
    "multer": "^2.1.1",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  },
  "engines": {
    "node": ">=20"
  }
}
